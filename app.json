{
  "expo": {
    "name": "Skinalo-mobile-app",
    "slug": "Skinalo-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/skinalo-icon.png",
    "scheme": "appwrite-callback-69babb040018e21dd179",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ideaTeam.Skinalo"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/skinalo-icon.png",
        "backgroundImage": "./assets/images/skinalo-icon.png",
        "monochromeImage": "./assets/images/skinalo-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ideaTeam.Skinalo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/skinalo-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "357e69f5-8995-4f49-8769-a37007a02638"
      }
    }
  }
}
